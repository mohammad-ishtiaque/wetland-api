# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/agroclima

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=30d

# Email (for OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ACIS API (no auth needed)
ACIS_BASE_URL=https://data.rcc-acis.org
AGACIS_BASE_URL=https://agacis.rcc-acis.org

# NRCS Soil Data Access (no auth needed)
SDA_BASE_URL=https://SDMDataAccess.sc.egov.usda.gov

# FCC Geocoder (no auth needed)
FCC_GEO_URL=https://geo.fcc.gov/api/census/area

# Station search
MAX_STATION_DISTANCE_MILES=100
WETS_YEAR_START=1971
WETS_YEAR_END=2000
